# Server Configuration
PORT=5001
NODE_ENV=development
HOST=localhost

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/healthcare_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# API Configuration
API_BASE_URL=http://localhost:5001
